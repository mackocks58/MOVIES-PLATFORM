rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /movies/{movieId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null && request.auth.token.email.toLowerCase().includes('admin');
    }
    match /posters/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null && request.auth.token.email.toLowerCase().includes('admin');
    }
  }
}
